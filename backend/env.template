# Healthcare Voice Agent - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LiveKit Configuration
# =============================================================================
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# =============================================================================
# AI Service API Keys
# =============================================================================
# OpenAI - for LLM (required)
OPENAI_API_KEY=sk-your-openai-api-key

# Deepgram - for Speech-to-Text (required)
DEEPGRAM_API_KEY=your-deepgram-api-key

# Cartesia - for Text-to-Speech (required)
CARTESIA_API_KEY=your-cartesia-api-key

# =============================================================================
# Backend API Configuration
# =============================================================================
BACKEND_URL=http://localhost:8000

# =============================================================================
# Agent Configuration (Optional)
# =============================================================================
# Speech-to-Text
DEEPGRAM_MODEL=nova-2
AGENT_LANGUAGE=en

# LLM
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# Text-to-Speech (Cartesia voice ID)
CARTESIA_VOICE_ID=248be419-c632-4f23-adf1-5324ed7dbf1d

# =============================================================================
# Database & Redis (for backend)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/healthcare_voice_agent
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Security (for backend)
# =============================================================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
ENCRYPTION_KEY=your-aes-256-encryption-key-change-in-production

# =============================================================================
# Optional: Twilio/SendGrid (for SMS/Email notifications)
# =============================================================================
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
