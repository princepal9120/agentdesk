{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/apps/gateway",
        "tsBuildInfoFile": "../../dist/apps/gateway/.tsbuildinfo",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@modules/*": [
                "src/modules/*"
            ],
            "@common/*": [
                "src/common/*"
            ],
            "@config/*": [
                "src/config/*"
            ],
            "@app/common": [
                "../../libs/common/src"
            ],
            "@app/common/*": [
                "../../libs/common/src/*"
            ],
            "@app/database": [
                "../../libs/database/src"
            ],
            "@app/database/*": [
                "../../libs/database/src/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "test",
        "**/*spec.ts"
    ]
}