# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/medvoice?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_REALTIME_MODEL=gpt-4-realtime-preview

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=your-deepgram-api-key

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Twilio (Voice Calls)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
GCP_STORAGE_BUCKET=medvoice-storage
GCP_PUBSUB_TOPIC=medvoice-events
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json

# CORS
CORS_ORIGIN=http://localhost:3001,https://yourdomain.com

# Logging
LOG_LEVEL=info

# Session
SESSION_SECRET=your-session-secret-change-in-production

# File Upload
MAX_FILE_SIZE=10485760

# Voice Agent
VOICE_AGENT_TIMEOUT=180000
VOICE_AGENT_MAX_RETRIES=3
VOICE_AGENT_LANGUAGE=en-US

# EHR Integration (Epic FHIR)
EPIC_CLIENT_ID=your-epic-client-id
EPIC_CLIENT_SECRET=your-epic-client-secret
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth

# EHR Integration (Athena)
ATHENA_API_KEY=your-athena-api-key
ATHENA_API_SECRET=your-athena-api-secret
ATHENA_PRACTICE_ID=your-practice-id

# Monitoring
SENTRY_DSN=your-sentry-dsn

# Webhooks
WEBHOOK_SECRET=your-webhook-secret
