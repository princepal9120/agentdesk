# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
DEV_AGENCY_ID=dev-agency
DEV_AGENCY_NAME=Local Demo Agency
VOICE_MODE=demo
VOICE_PROVIDER=openai

# ── Local OSS quickstart ─────────────────────────────
# Minimum path for local demo mode:
# - set OPENAI_API_KEY
# - keep VOICE_MODE=demo
# - keep VOICE_PROVIDER=openai
# This path avoids Clerk setup and gets the landing page + dashboard flow running.

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentdesk

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LiveKit ──────────────────────────────────────────
# Still part of the broader runtime and production-oriented path.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── AI Providers ─────────────────────────────────────
OPENAI_API_KEY=sk-...
# Used in fuller production-oriented voice setups.
DEEPGRAM_API_KEY=...
CARTESIA_API_KEY=...

# ── Twilio ───────────────────────────────────────────
# Required for real phone calling, not for the basic local dashboard/demo flow.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── Stripe ───────────────────────────────────────────
# Optional for local onboarding.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...
